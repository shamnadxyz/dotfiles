set shell bash
set ifs "\n"
set incsearch true

set scrolloff 10
set drawbox false
# Use the `dim` attribute instead of underline for the cursor in the preview pane
set cursorpreviewfmt "\033[7;2m"
set ignorecase true

# show the result of execution of previous commands
map ` !true

set previewer ~/.config/lf/preview

map D delete

cmd open &{{
  case $(file --mime-type -Lb $f) in
    text/*) lf -remote "send $id \$$EDITOR \$fx";;
    *) for f in $fx; do $OPENER $f > /dev/null 2> /dev/null & done;;
  esac
}}

map o &mimeopen $f
map O $mimeopen --ask $f

cmd extract-to-dir ${{
  read -p "Extract to: " directory
  mkdir -p "$directory"
  set -f
  case $f in
    *.rar|*.7z|*.zip)
      7z x "$f" -o"$directory"
      ;;
    *.tar|*.tar.bz|*.tar.bz2|*.tbz|*.tbz2|*.tar.gz|*.tgz|*.tar.xz|*.txz)
      tar -xf "$f" -C "$directory"
      ;;
  esac
}}
map ad extract-to-dir

cmd extract-here ${{
  set -f
  case $f in
    *.rar|*.7z|*.zip)
      7z x "$f"
      ;;
    *.tar|*.tar.bz|*.tar.bz2|*.tbz|*.tbz2|*.tar.gz|*.tgz|*.tar.xz|*.txz)
      tar -xf "$f"
      ;;
  esac
}}
map ax extract-here

cmd add-to-archive ${{
  set -f
  printf "$fx\n"
  read -p "Archive name:" name
  7z a "$name" "$fx"
}}
map aa add-to-archive

cmd zi ${{
  result="$(zoxide query -i | sed 's/\\/\\\\/g;s/"/\\"/g')"
  lf -remote "send $id cd \"$result\""
}}
map Z zi 

cmd on-cd &{{
  zoxide add "$PWD"
}}

# Sort
cmd sort-by-access :{{ set sortby atime; set info atime; }}
map sa sort-by-access

cmd sort-by-creation :{{ set sortby btime; set info btime; }}
map sc sort-by-creation

cmd sort-by-extension :{{ set sortby ext; set info; }}
map se sort-by-extension

cmd sort-by-modification :{{ set sortby time; set info time; }}
map st sort-by-modification

cmd sort-by-name :{{ set sortby name; set info; }}
map sN sort-by-name

cmd sort-by-natural-name :{{ set sortby natural; set info; }}
map sn sort-by-natural-name

cmd sort-by-size :{{ set sortby size; set info size; }}
map ss sort-by-size

map sb
