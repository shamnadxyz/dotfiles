#!/usr/bin/env bash

SCREENSHOT_PATH="${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots"

# Generate timestamped filename
FILENAME="$(date '+%Y-%m-%d-%H-%M-%S-%N.png')"

DEPENDENCIES=("fuzzel" "slurp" "grim")

check_dependencies() {
  local missing=()
  for cmd in "${DEPENDENCIES[@]}"; do
    if ! command -v "${cmd}" &>/dev/null; then
      missing+=("$cmd")
    fi
  done

  if ((${#missing[@]})); then
    fyi --urgency critical "  Error" "Missing binaries: ${missing[*]}"
    exit 1
  fi
}

pick_mode() {
  local modes
  modes=(
    "󰍺  Desktop"
    "󰍹  Output"
    "󰒅  Region"
  )

  local selection
  selection="$(printf '%s\n' "${modes[@]}" |
    fuzzel --dmenu --minimal-lines --only-match --width 20)" || exit 1

  local mode
  # Remove the icon from the selected mode
  mode="${selection#*  }"

  # Make it lowercase
  printf '%s' "${mode,,}"
}

take_screenshot() {
  local mode
  mode="$1"

  case "$mode" in
  desktop)
    sleep 0.3
    grim "${SCREENSHOT_PATH}/${FILENAME}"
    ;;
  output)
    grim -g "$(slurp -o)" "${SCREENSHOT_PATH}/${FILENAME}"
    ;;
  region)
    grim -g "$(slurp)" "${SCREENSHOT_PATH}/${FILENAME}"
    ;;
  *)
    fyi "Invalid option" "$mode"
    exit 1
    ;;
  esac

  status=$?

  if [[ "$status" -eq 0 ]]; then
    fyi " Screenshot Captured" "$FILENAME"
  fi
}

main() {
  # Ensure directory exists
  mkdir -p "$SCREENSHOT_PATH"

  check_dependencies

  local mode
  mode="$1"

  if [ -z "$mode" ]; then
    mode="$(pick_mode)" || exit 1
  fi

  take_screenshot "$mode"
}

main "$@"
