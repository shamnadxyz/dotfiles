#!/usr/bin/env bash
# DEPENDENCIES: fuzzel fyi grim slurp

readonly SCREENSHOT_PATH="${XDG_PICTURES_DIR:-$HOME/Pictures}/Screenshots"
readonly -a MODES=(
  "󰍺  Desktop"
  "󰍹  Output"
  "󰒅  Region"
)

pick_mode() {
  local mode selection

  selection="$(printf '%s\n' "${MODES[@]}" |
    fuzzel --dmenu --minimal-lines --only-match --width 20)"

  mode="${selection##* }"

  # Convert to lowercase
  printf '%s' "${mode,,}"
}

take_screenshot() {
  local mode filename
  mode="$1"
  filename="$(date '+%Y-%m-%d-%H-%M-%S-%N.png')"

  case "$mode" in
  desktop)
    grim "${SCREENSHOT_PATH}/${filename}"
    ;;
  output)
    grim -g "$(slurp -o)" "${SCREENSHOT_PATH}/${filename}"
    ;;
  region)
    grim -g "$(slurp)" "${SCREENSHOT_PATH}/${filename}"
    ;;
  *)
    printf "%s\n" "screenshot: '$mode': invalid option" >&2
    exit 1
    ;;
  esac

  status=$?

  if [[ "$status" -eq 0 ]]; then
    fyi "Screenshot Captured" "$filename"
  else
    fyi "Screenshot Failed" "$filename"
  fi
}

main() {
  mkdir -p "$SCREENSHOT_PATH"

  local mode
  mode="$1"

  if [ -z "$mode" ]; then
    mode="$(pick_mode)"
  fi

  take_screenshot "$mode"
}

main "$@"
