#!/usr/bin/env bash
#
# A wallpaper selector script for setting the wallpaper using swaybg
# swayimg is used for picker and wallust to generate colorscheme
# Dependencies:
#   swaybg and swayimg
# Optional dependencies:
#   libnotify, dunst, and wallust

readonly WALLPAPER_PATH="$HOME/.cache/wallpaper"

notify_error() {
  echo "$*" >&2
  notify-send -u critical "  Error" "$*"
}

check_dependencies() {
  declare -a missing_deps

  if ! command -v "swayimg" &>/dev/null; then
    missing_deps+=("swayimg")
  fi

  if ! command -v "swaybg" &>/dev/null; then
    missing_deps+=("swaybg")
  fi

  if [[ "${#missing_deps[@]}" -gt 0 ]]; then
    notify_error "Missing dependencies: ${missing_deps[*]}"
    exit 1
  fi
}

restart_waybar() {
  pkill waybar
  waybar &>/dev/null &
  disown
}

update_colorscheme() {
  if ! command -v wallust &>/dev/null; then
    notify_error "Wallust not found"
    return 1
  fi

  if ! wallust run "$WALLPAPER_PATH" -q &>/dev/null; then
    notify_error "Failed to update colorscheme"
    return 1
  fi

  restart_waybar
}

set_wallpaper() {
  local wallpaper="$1"

  local absolute_path
  absolute_path="$(realpath "$wallpaper")"

  ln -sf "$absolute_path" "$WALLPAPER_PATH"

  pkill dunst
  pkill swaybg

  swaybg -i "$WALLPAPER_PATH" -m fill &>/dev/null &
  disown

  update_colorscheme
}

main() {
  check_dependencies

  local wallpapers_path="${WALLPAPERS:-$HOME/Pictures/Wallpapers}"

  local path="$1"

  if [[ -f "$path" ]]; then
    set_wallpaper "$path"
    return 0
  elif [[ -d "$path" ]]; then
    wallpapers_path="$path"
  fi

  if pgrep --exact "swayimg" >/dev/null; then
    exit 1
  fi

  if [[ ! -d "$wallpapers_path" ]]; then
    notify_error "Wallpapers directory does not exist: $wallpapers_path"
    exit 1
  fi

  notify-send "Wallpaper Selector" "Press 'Shift+Return' to select"

  # Launch swayimg to pick wallpaper
  wallpaper="$(swayimg -g "$wallpapers_path" --config ~/.config/swayimg/pick.lua)"

  if [[ -f "$wallpaper" ]]; then
    set_wallpaper "$wallpaper"
  fi
}

main "$@"
