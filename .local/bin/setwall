#!/usr/bin/env bash
# DEPENDENCIES: swayimg swaybg

readonly WALLPAPER="$HOME/.cache/wallpaper"
WALLPAPERS="${WALLPAPERS:-$HOME/Pictures/Wallpapers}"

update_colorscheme=0

notify_error() {
  echo "$*" >&2
  fyi --urgency critical "Error" "$*"
}

reload_waybar() { pkill -SIGUSR2 waybar; }

generate_colorscheme() {
  if ! wallust run "$WALLPAPER" -q; then
    notify_error "Failed to generate the colorscheme"
    return 1
  fi

  reload_waybar
}

set_wallpaper() {
  local wallpaper absolute_path
  wallpaper="$1"

  if [[ ! -f "$wallpaper" ]]; then
    notify_error "$wallpaper: No such file"
    return 1
  fi

  absolute_path="$(realpath "$wallpaper")"
  ln -sf "$absolute_path" "$WALLPAPER"

  pkill swaybg
  swaybg -i "$WALLPAPER" -m fill &>/dev/null &
  disown

  ((update_colorscheme)) && generate_colorscheme
}

pick_wallpaper() {
  if [[ ! -d "$WALLPAPERS" ]]; then
    notify_error "'$WALLPAPERS': No such directory"
    exit 1
  fi

  local nid
  nid="$(fyi --print-id "Wallpaper Selector" "Press 'Shift+Return' to select")"
  nid="${nid##*=}"

  wallpaper="$(swayimg -g "$WALLPAPERS" --config ~/.config/swayimg/pick.lua)"

  fyi --close="$nid"

  [[ -n "$wallpaper" ]] || exit

  set_wallpaper "$wallpaper"
}

show_help() {
  printf "Usage: %s [-f IMAGE] [-d WALLPAPERS_DIR]\n" "$0"
}

handle_args() {
  while getopts f:d:uh opt; do
    case "$opt" in
      f) set_wallpaper "$OPTARG"; exit ;;
      d) WALLPAPERS="$OPTARG" ;;
      u) update_colorscheme=1 ;;
      h) show_help; exit ;;
      ?) show_help >&2; exit 2 ;;
    esac
  done
  shift $((OPTIND - 1))
}

main() {
  (($#)) && handle_args "$@"
  pick_wallpaper
}

main "$@"
