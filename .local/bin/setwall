#!/usr/bin/env bash

readonly WALLPAPER_PATH="$HOME/.cache/wallpaper"
readonly DEPENDENCIES=("swayimg" "swaybg")
WALLPAPERS_PATH="${WALLPAPERS:-$HOME/Pictures/Wallpapers}"

notify_error() {
  echo "$*" >&2
  fyi --urgency critical "Error" "$*"
}

bin_exist() {
  command -v "$1" &>/dev/null
}

check_dependencies() {
  declare -a missing_deps

  for dep in "${DEPENDENCIES[@]}";do
    if ! bin_exist "$dep";then
      missing_deps+=("$dep")
    fi
  done

  if (("${#missing_deps[@]}")); then
    notify_error "Missing dependencies: ${missing_deps[*]}"
    exit 1
  fi
}

reload_waybar() {
  pkill -SIGUSR2 waybar
}

update_colorscheme() {
  if ! wallust run "$WALLPAPER_PATH" -q; then
    notify_error "Failed to update the colorscheme"
    return 1
  fi

  reload_waybar
}

set_wallpaper() {
  local wallpaper absolute_path
  wallpaper="$1"

  if [[ ! -f "$wallpaper" ]]; then
    notify_error "$wallpaper: No such file"
    return 1
  fi

  absolute_path="$(realpath "$wallpaper")"
  ln -sf "$absolute_path" "$WALLPAPER_PATH"

  pkill swaybg
  swaybg -i "$WALLPAPER_PATH" -m fill &>/dev/null &
  disown

  update_colorscheme
}

pick_wallpaper() {
  if [[ ! -d "$WALLPAPERS_PATH" ]]; then
    notify_error "'$WALLPAPER_PATH': No such directory"
    exit 1
  fi

  # print-id option currently prints id=ID on stdout
  nid="$(fyi --print-id "Wallpaper Selector" "Press 'Shift+Return' to select")"
  nid="${nid##*=}"

  wallpaper="$(swayimg -g "$WALLPAPERS_PATH" --config ~/.config/swayimg/pick.lua)" \
    || { notify_error "Unexpected Error"; exit 1; }

  fyi --close="$nid"
  set_wallpaper "$wallpaper"
}

show_help() {
  printf "Usage: %s [-f IMAGE] [-d WALLPAPERS_DIR]\n" "$0"
}

handle_args() {
  while getopts f:d:h opt; do 
    case "$opt" in
      f) set_wallpaper "$OPTARG"; exit ;;
      d) WALLPAPERS_PATH="$OPTARG" ;;
      h) show_help; exit; ;;
      ?) show_help >&2; exit 2; ;;
    esac
  done
  shift $((OPTIND - 1))
}

main() {
  check_dependencies
  (($#)) && handle_args "$@"
  pick_wallpaper
}

main "$@"
