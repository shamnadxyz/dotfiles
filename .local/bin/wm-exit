#!/usr/bin/env bash

readonly WM="${WM:-Hyprland}"

check_wm() {
  local error_message="Unknown WM: $WM"
  if [[ ! "$WM" =~ ^(Hyprland|sway)$ ]]; then
    echo "$error_message" >&2
    fyi "$error_message"
  fi
}

PROMPT="You pressed the exit shortcut.
Do want to exit $WM?"

OPTIONS=$'No\nYes'

pick_option() {
  printf "%s" "$OPTIONS" | fuzzel --dmenu --minimal-lines --only-match --mesg "$PROMPT"
}

exit_wm() {
  case "$WM" in
  sway)
    swaymsg exit
    ;;
  Hyprland)
    hyprctl dispatch 'hl.dsp.exit()'
    ;;
  esac
}

main() {
  local option

  check_wm

  option="$(pick_option)"

  if [[ "$option" == "Yes" ]]; then
    exit_wm
  fi
}

main
