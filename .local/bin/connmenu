#!/usr/bin/env bash

declare -a CONNECTIONS

# Populates the global array with network connections.
# Globals:
#  CONNECTIONS
get_connections() {
  local count
  readarray -t CONNECTIONS < <(
    nmcli -t -f TYPE,NAME,ACTIVE connection |
      awk -F ':' '$1 != "bridge" && $1 != "loopback" {print $2 ":" $3}'
  )

  count="${#CONNECTIONS[@]}"

  if ((count == 0)); then
    notify-send "No connections available"
    exit 1
  fi
}

# Opens the available connections in dmenu.
# Output:
#  writes connection name and active to stdout
pick_connection() {
  local connection name active index
  index="$(
    printf "%s\n" "${CONNECTIONS[@]}" |
      awk -F ':' '{print ($2 == "yes" ? " " : " "), $1}' |
      fuzzel --dmenu --index --only-match
  )" || exit 1

  connection="${CONNECTIONS[$index]}"

  # connection='name:active'
  name="${connection%%:*}"
  active="${connection##*:}"

  printf "%s %s\n" "$name" "$active"
}

main() {
  get_connections || exit 1
  local name active
  read -r name active < <(pick_connection)

  if [ "$active" = "no" ]; then
    nmcli connection up "$name"
  elif [ "$active" = "yes" ]; then
    nmcli connection down "$name"
  fi
}

main
