#!/usr/bin/env bash
# DEPENDENCIES: fuzzel wl-clipboard

readonly DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/clipboard"
readonly CLIPBOARD="${DATA_HOME}/clipboard"
readonly TRASH="${DATA_HOME}/trash"

ENTRY=""

notify_error() {
  echo "$*" >&2
  fyi "Error" "$*"
  exit 1
}

show_help() {
  printf "Usage: clipboard [OPTION]

  -a, --add       add clipboard content to the storage

  -d, --delete    delete entry from the storage

  -c, --copy      copy from storage to the system clipboard

  -h, --help      display help\n"
}

select_entry() {
  ENTRY="$(fuzzel --dmenu --only-match --prompt 'Copy > ' <"$CLIPBOARD")"
  [ -z "$ENTRY" ] && exit 1
}

add_to_storage() {
  text="$(wl-paste)"
  [ -z "$text" ] && exit 1

  # replace newlines with literal \n
  compact_text="$(printf "%s" "$text" | awk 'NR>1 {printf "\\n" {printf "%s", $0')"

  if ! grep -Fx "$compact_text" "$CLIPBOARD" &>/dev/null; then
    printf "%s\n" "$compact_text" >>"$CLIPBOARD"
  fi
}

exit_on_empty() {
  [ ! -s "$CLIPBOARD" ] && notify_error "Clipboard is empty"
}

delete_from_storage() {
  exit_on_empty
  local text match line_number

  select_entry
  match="$(grep -Fx "$ENTRY" -n "$CLIPBOARD")"
  if [[ -n "$match" ]]; then
    line_number="${match%%:*}"
    sed -i "${line_number}d" "$CLIPBOARD"
    printf "%s\n" "$text" >>"$TRASH"
  fi
}

copy_to_clipboard() {
  exit_on_empty
  select_entry
  wl-copy "$(printf '%b' "$ENTRY")"
}

handle_args() {
  # Enforce exactly one argument
  if [ "$#" -ne 1 ]; then
    show_help
    exit 1
  fi

  case "$1" in
  -a | --add) add_to_storage ;;
  -d | --delete) delete_from_storage ;;
  -c | --copy) copy_to_clipboard ;;
  -h | --help) show_help ;;
  *) show_help; exit 1 ;;
  esac
}

main() {
  mkdir -p "$DATA_HOME"
  handle_args "$@"
}

main "$@"
