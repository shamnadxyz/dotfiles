# FZF CONFIG
bg_selected="#55586c"
fg="#c6c8d1"
accent="#b3daf9"
accent_soft="#91acd1"
highlight="#b3daf9"
pointer="#fac5c7"
marker="#d1cffb"
border="#d8d4cd"

export FZF_DEFAULT_OPTS="
  --bind ctrl-y:accept
  --layout=reverse --style=full
  --color=spinner:$pointer,hl:$highlight
  --color=fg:$fg,header:$accent,info:$accent_soft,pointer:$pointer
  --color=marker:$marker,fg+:$fg,prompt:$accent_soft,hl+:$highlight
  --color=selected-bg:$bg_selected
  --color=border:$border,label:$fg
"
unset bg bg_alt bg_selected fg accent accent_soft highlight pointer marker border

alias ls='ls \
  --indicator-style=classify \
  --color \
  --group-directories-first \
  --sort=time'
if command -v eza >/dev/null; then
  alias ls='eza \
  --icons --color \
  --group-directories-first \
  --sort modified --reverse'
fi
alias mkdir='mkdir -pv'
alias mv='mv -vi'
alias vim='nvim'
alias vi='nvim'
alias img='swayimg'
# vim: ft=bash
